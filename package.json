    "immer": "^11.1.8",
    "jspdf": "^4.2.1",
    "localforage": "^1.10.0",
    "lucide-react": "^1.17.0",
    "motion": "^12.40.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-virtuoso": "^4.18.7",
    "tailwind-merge": "^3.6.0",
    "tesseract.js": "^7.0.0",
